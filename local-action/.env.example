# Inputs consumed by the action, used by `ddev npm run local-action`.
# Copy to `local-action/.env` and edit. INPUT_* keys map to action.yml `inputs.*`.

INPUT_PATTERN='\[(BUGFIX|DOCS|FEATURE|TASK)\] .+$'
INPUT_FLAGS=gm
INPUT_ERROR='Your first line has to contain a commit type like "[BUGFIX]".'
INPUT_EXCLUDETITLE=false
INPUT_EXCLUDEDESCRIPTION=false
INPUT_CHECKALLCOMMITMESSAGES=false
INPUT_ACCESSTOKEN=

# Simulated GitHub event. GITHUB_EVENT_NAME selects the code path
# (`push`, `pull_request`, `pull_request_target`). GITHUB_EVENT_PATH points to
# a JSON file holding the webhook payload — @actions/github reads it to
# populate `github.context.payload`. local-action/event.json ships a sample
# push payload; for pull request testing, supply a payload with
# `pull_request` / `repository` keys instead.
GITHUB_EVENT_NAME=push
GITHUB_EVENT_PATH=local-action/event.json
